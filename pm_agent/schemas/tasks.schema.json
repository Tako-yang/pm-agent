{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "required": ["project_id", "tasks", "version"],
  "properties": {
    "project_id": {"type": "string"},
    "version": {"type": "integer"},
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "acceptance_criteria"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^task_[0-9]{3,}_[a-z0-9_]+$"
          },
          "title": {"type": "string", "maxLength": 100},
          "description": {"type": "string", "maxLength": 1000},
          "status": {"enum": ["pending", "running", "done", "failed", "blocked"]},
          "assigned_cli": {"type": ["string", "null"]},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "acceptance_criteria": {"type": "string"},
          "files_owned": {"type": "array", "items": {"type": "string"}},
          "attempts": {"type": "integer", "minimum": 0},
          "max_attempts": {"type": "integer", "minimum": 1, "default": 3},
          "last_feedback_summary": {"type": "string"},
          "created_at": {"type": "string"},
          "updated_at": {"type": "string"}
        }
      }
    }
  }
}
